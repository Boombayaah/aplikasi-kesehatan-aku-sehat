<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/menu_item_bg"
    android:elevation="12dp">

    <!-- Header Blue Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hero_bottom_curve"
        android:padding="20dp">

        <ImageView
            android:id="@+id/iconLogin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_lock_lock"
            android:background="@drawable/rounded_square_bg"
            android:padding="8dp"
            android:tint="@color/White" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iconLogin"
            android:layout_marginStart="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk Akun"
                android:textColor="@color/White"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Akses dashboard dan riwayat\nmedis Anda"
                android:textColor="@color/White"
                android:textSize="10sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnCloseLogin"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/White"/>
    </RelativeLayout>

    <!-- Form Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nomor Telepon"
            android:textColor="@color/TextDark"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etLoginIdentifier"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/search_bar_bg"
            android:hint="08xx xxxx xxxx"
            android:inputType="phone"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:maxLength="13"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/TextDark"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/search_bar_bg"
            android:hint="Minimal 8 karakter"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <CheckBox
            android:id="@+id/cbRememberMe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingat saya"
            android:textSize="12sp"
            android:textColor="@color/TextSecondary"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnDoLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Masuk Sekarang"
            android:textAllCaps="false"
            android:backgroundTint="@color/PrimaryBlue"
            android:textColor="@color/White"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="Belum punya akun? Daftar di sini"
            android:textSize="12sp"
            android:textColor="@color/TextSecondary"/>
    </LinearLayout>
</LinearLayout>