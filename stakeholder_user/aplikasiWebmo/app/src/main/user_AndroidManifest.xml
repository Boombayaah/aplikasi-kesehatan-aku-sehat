<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://tools.android.com/apk/res/tools">

     <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="AkuSehat"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name="com.example.aplikasiwebmo.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.aplikasiwebmo.HomeActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.LoginActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.SettingsActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.ProfileActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.ScheduleActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.CheckinActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.QueueStatusActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.MedicalHistoryActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.MedicalRecordDetailActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.MedicalBillingActivity"
            android:exported="false" />

        <activity
            android:name="com.example.aplikasiwebmo.KlinikFlowActivity"
            android:exported="false" />

    </application>

</manifest>