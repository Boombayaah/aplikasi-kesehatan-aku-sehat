<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <!-- Global Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <!-- Hidden for Java compat -->
    <ImageView android:id="@+id/btnBillingBack" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:contentDescription="Back" />

    <ScrollView
        android:id="@+id/scrollBillingContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/globalFooter"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Estimasi Harga"
                android:textColor="#06161D"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Tanggal" android:textColor="#666666"/>
                <TextView android:id="@+id/tvBillingDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/search_bar_bg" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="-" android:textColor="#06161D" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Waktu" android:textColor="#666666"/>
                <TextView android:id="@+id/tvBillingTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/search_bar_bg" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="-" android:textColor="#06161D" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Biaya Layanan Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Biaya Layanan"
                android:textColor="#06161D"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/llServiceCosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                <!-- Consultation item injected here -->
            </LinearLayout>

            <!-- Biaya Obat Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Biaya Obat"
                android:textColor="#06161D"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/llMedicineCosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <!-- Medication items injected here -->
            </LinearLayout>

            <!-- Total Harga Section (Bottom Right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Harga :  "
                    android:textColor="#06161D"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBillingTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_square_bg"
                    android:backgroundTint="#FFEBEE"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="10dp"
                    android:text="Rp -"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llBillingEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/globalFooter"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">
        <TextView
            android:id="@+id/tvNoBillingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tidak ada biaya pada saat ini"
            android:textColor="#666666"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Global Footer -->
    <include
        android:id="@+id/globalFooter"
        layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>