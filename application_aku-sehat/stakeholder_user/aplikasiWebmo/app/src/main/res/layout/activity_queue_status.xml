<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <!-- Global Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <ScrollView
        android:id="@+id/scrollQueueContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/globalFooter"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Ticket Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_square_bg"
                android:backgroundTint="@color/White"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#00A693"
                    android:padding="32dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/d_checklist"
                        android:layout_marginBottom="16dp"
                        android:contentDescription="Checkmark"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/registration_success"
                        android:textColor="@color/White"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/queue_number_label"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvQueueNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#00A693"
                        android:textSize="72sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvQueueArrived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/queue_arrived"
                        android:textColor="#FF4444"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tvQueuePatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#06161D"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvQueueDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#9E9E9E"
                        android:layout_marginTop="4dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="24dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/current_queue_label" android:textColor="#757575"/>
                        <TextView android:id="@+id/tvCurrentQueue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#00A693" android:textStyle="bold" android:textSize="18sp"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnFinishQueue"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Selesaikan antrian"
                android:textAllCaps="false"
                android:backgroundTint="#00A693"
                android:textColor="@color/White"
                android:textStyle="bold"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llQueueEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/globalFooter"
        android:gravity="center"
        android:padding="24dp">
        <TextView
            android:id="@+id/tvNoScheduleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum ada antrean aktif"
            android:textColor="#CCCCCC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Global Footer -->
    <include
        android:id="@+id/globalFooter"
        layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>