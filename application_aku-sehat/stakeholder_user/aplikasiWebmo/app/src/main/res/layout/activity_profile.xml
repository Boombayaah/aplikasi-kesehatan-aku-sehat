<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/rlProfileHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnProfileBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            android:layout_centerVertical="true"
            android:padding="4dp"
            app:tint="@color/PrimaryBlue"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="User Profile"
            android:textColor="@color/PrimaryBlue"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rlProfileHeader"
        android:layout_above="@id/btnLogout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Profile Picture with Camera Icon -->
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:id="@+id/ivProfileUserPic"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/d_logo1"
                    android:scaleType="centerCrop"
                    android:background="@drawable/rounded_square_bg"
                    android:padding="4dp"/>

                <ImageView
                    android:id="@+id/btnProfileChangePic"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignBottom="@id/ivProfileUserPic"
                    android:layout_alignEnd="@id/ivProfileUserPic"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="@drawable/rounded_square_bg"
                    android:padding="6dp"
                    app:tint="@color/PrimaryBlue"/>
            </RelativeLayout>

            <!-- Fields -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etProfileFirstName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/search_bar_bg"
                android:paddingHorizontal="16dp"
                android:hint="Nama Lengkap"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIK"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/search_bar_bg"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/tvProfileNIK"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="-"
                    android:textSize="14sp"
                    android:textColor="@color/Black"/>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tanggal Lahir"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <RelativeLayout
                android:id="@+id/btnSelectBirthDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/search_bar_bg"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvProfileBirthDate"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="Pilih Tanggal Lahir"
                    android:textSize="14sp"
                    android:textColor="@color/Black"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/PrimaryBlue"/>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nomor BPJS"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etProfileBpjs"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/search_bar_bg"
                android:paddingHorizontal="16dp"
                android:hint="Masukkan nomor BPJS"
                android:textSize="14sp"
                android:maxLength="100"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alamat"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etProfileAddress"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/search_bar_bg"
                android:padding="16dp"
                android:hint="Masukkan alamat lengkap"
                android:textSize="14sp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etProfileMobile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/search_bar_bg"
                android:paddingHorizontal="16dp"
                android:hint="+62 xxxx xxxx"
                android:inputType="phone"
                android:textSize="14sp"
                android:maxLength="13"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnProfileSave"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="SAVE"
                android:textStyle="bold"
                android:textColor="@color/White"
                android:backgroundTint="@color/PrimaryBlue"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="300dp"
        android:layout_height="55dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="Log Out"
        android:textColor="@color/White"
        android:backgroundTint="#FF4444"
        android:textAllCaps="false"
        style="@style/Widget.MaterialComponents.Button"/>

</RelativeLayout>