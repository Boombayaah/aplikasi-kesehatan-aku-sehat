<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <!-- Global Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/globalFooter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_square_bg"
                android:backgroundTint="@color/White"
                android:orientation="vertical"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">
                <RelativeLayout
                    android:id="@+id/headerSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Buat Jadwal"
                        android:textColor="#06161D"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/arrowSchedule"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_down_float"/>
                </RelativeLayout>
                <LinearLayout
                    android:id="@+id/contentSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:src="@drawable/d_flowchartbuatjadwal"
                        android:contentDescription="Flowchart Buat Jadwal"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Section 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_square_bg"
                android:backgroundTint="@color/White"
                android:orientation="vertical"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">
                <RelativeLayout
                    android:id="@+id/headerConsultation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Konsultasi"
                        android:textColor="#06161D"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/arrowConsultation"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_down_float"/>
                </RelativeLayout>
                <LinearLayout
                    android:id="@+id/contentConsultation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:src="@drawable/d_flowchartkonsultasi"
                        android:contentDescription="Flowchart Konsultasi"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Section 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_square_bg"
                android:backgroundTint="@color/White"
                android:orientation="vertical"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">
                <RelativeLayout
                    android:id="@+id/headerInsurance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Klaim Asuransi"
                        android:textColor="#06161D"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/arrowInsurance"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_down_float"/>
                </RelativeLayout>
                <LinearLayout
                    android:id="@+id/contentInsurance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:src="@drawable/d_flowchartklaimasuransi"
                        android:contentDescription="Flowchart Klaim Asuransi"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Global Footer -->
    <include
        android:id="@+id/globalFooter"
        layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>