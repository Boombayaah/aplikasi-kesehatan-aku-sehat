<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- navbar -->
        <LinearLayout
            android:id="@+id/navbar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="@color/background">

            <ImageView
                android:id="@+id/logoButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/c_logo"
                android:scaleType="fitCenter"
                android:contentDescription="logo" />

            <TextView
                android:id="@+id/akuSehat"
                style="@style/TitleText"
                android:layout_width="111dp"
                android:layout_height="30dp"
                android:layout_marginLeft="5dp"
                android:text="AkuSehat"
                android:textSize="20dp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/logoProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/b_ic_profile"
                android:layout_marginTop="1dp" />


            <TextView
                android:id="@+id/profileButton"
                style="@style/BodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:textSize="15dp"/>

        </LinearLayout>

        <!-- NAVBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:background="@color/background">

            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengaturan Staff"
                android:textColor="@color/primary_text"
                android:textSize="24sp" />

        </LinearLayout>

        <!-- FORM CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/a_card_outline"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- PROFILE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/a_circle_outline"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/btnUploadProfil"
                    style="@style/BodyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/a_card_outline"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Upload Profil"
                    android:textColor="@color/secondary" />

            </LinearLayout>

            <!-- NIK -->
            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="NIK"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/inputNik"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/a_card_outline"
                android:inputType="number"
                android:paddingHorizontal="12dp" />

            <!-- NAMA -->
            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Nama"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/inputNama"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/a_card_outline"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp" />

            <!-- JABATAN -->
            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Jabatan"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/inputJabatan"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/a_card_outline"
                android:paddingHorizontal="12dp" />

            <!-- EMAIL -->
            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Email"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/inputEmail"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/a_card_outline"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp" />

            <!-- NO TELP -->
            <TextView
                style="@style/Title2Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="No. Telp"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/inputNoTelp"
                style="@style/BodyText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/a_card_outline"
                android:inputType="phone"
                android:paddingHorizontal="12dp" />

            <!-- BUTTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnBatal"
                    style="@style/Title2Text"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/a_card_outline"
                    android:gravity="center"
                    android:text="Batal"
                    android:textColor="@color/secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/btnSimpan"
                    style="@style/Title2Text"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@color/secondary"
                    android:gravity="center"
                    android:text="Simpan"
                    android:textColor="@color/surface"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>